{
  "name": "claude-agent-scaffold",
  "version": "0.1.0",
  "description": "Two-phase scaffolder for multi-agent AI setups: a static npx installer that detects your stack and lays down /.ai guideline templates, plus a Claude Code skill that fills them in interactively.",
  "type": "module",
  "license": "MIT",
  "bin": {
    "claude-agent-scaffold": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@clack/prompts": "^0.7.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0"
  }
}
